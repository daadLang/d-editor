{
  "name": "daad-ide",
  "version": "0.0.1",
  "description": "Minimal IDE for ض (Ḍād) Arabic Programming Language",
  "type": "module",
  "main": "src/bun/index.ts",
  "scripts": {
    "start": "vite build && bunx electrobun dev",
    "dev": "bunx electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && bunx electrobun build --env=canary"
  },
  "keywords": [
    "electrobun",
    "bun",
    "ide",
    "arabic",
    "daad"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.12.0",
    "@codemirror/commands": "^6.3.3",
    "@codemirror/gutter": "^0.19.9",
    "@codemirror/lang-python": "^6.1.4",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.23.1",
    "@fsegurai/codemirror-theme-bundle": "^6.4.2",
    "@lezer/highlight": "^1.2.0",
    "@lezer/lr": "^1.4.0",
    "codemirror": "^6.0.1",
    "electrobun": "1.18.1",
    "file-icons-js": "^1.1.0"
  }
}
